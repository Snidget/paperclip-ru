{
  "name": "plugin-paperclip-ru",
  "version": "1.0.5",
  "description": "Russian UI localization for Paperclip",
  "type": "module",
  "author": {
    "name": "Snidget"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Snidget/plugin-paperclip-ru.git"
  },
  "homepage": "https://github.com/Snidget/plugin-paperclip-ru#readme",
  "bugs": {
    "url": "https://github.com/Snidget/plugin-paperclip-ru/issues"
  },
  "license": "MIT",
  "files": [
    "dist/"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "scripts": {
    "build": "node ./scripts/clean-dist.mjs && tsc && node ./scripts/build-worker.mjs && node ./scripts/build-ui.mjs",
    "clean": "node ./scripts/clean-dist.mjs",
    "typecheck": "pnpm --filter @paperclipai/plugin-sdk build && tsc --noEmit"
  },
  "devDependencies": {
    "@paperclipai/plugin-sdk": "^2026.416.0",
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "esbuild": "^0.27.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
